<!DOCTYPE html>
<html>
<head>
    <title>AJIO - Fashion Store</title>
    <link rel="stylesheet" href="style.css">
</head>

<body>

<header>
    <div class="logo">AJIO</div>

    <nav>
        <a href="#">Men</a>
        <a href="#">Women</a>
        <a href="#">Kids</a>
        <a href="#">Beauty</a>
        <a href="#">Sale</a>
    </nav>

    <div class="search">
        <input type="text" placeholder="Search AJIO">
        <button>Search</button>
    </div>
</header>


<section class="banner">
    <h1>Fashion For Everyone</h1>
    <p>Trendy styles at amazing prices</p>
    <button>Shop Now</button>
</section>


<h2>Trending Categories</h2>

<section class="categories">

    <div class="card">
        <img src="https://via.placeholder.com/200">
        <h3>Men Fashion</h3>
    </div>

    <div class="card">
        <img src="https://via.placeholder.com/200">
        <h3>Women Fashion</h3>
    </div>

    <div class="card">
        <img src="https://via.placeholder.com/200">
        <h3>Footwear</h3>
    </div>

    <div class="card">
        <img src="https://via.placeholder.com/200">
        <h3>Accessories</h3>
    </div>

</section>


<h2>Featured Products</h2>

<section class="products">

    <div class="product">
        <img src="https://via.placeholder.com/180">
        <h3>Casual Shirt</h3>
        <p>₹999</p>
        <button>Add to Cart</button>
    </div>


    <div class="product">
        <img src="https://via.placeholder.com/180">
        <h3>Women's Dress</h3>
        <p>₹1499</p>
        <button>Add to Cart</button>
    </div>


    <div class="product">
        <img src="https://via.placeholder.com/180">
        <h3>Shoes</h3>
        <p>₹1999</p>
        <button>Add to Cart</button>
    </div>

</section>


<footer>
    <p>© 2026 AJIO Fashion Store | All Rights Reserved</p>
</footer>


</body>
</html>